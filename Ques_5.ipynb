      "20 10\n"
     ]
    }
   ],
   "source": [
    "def swap(a, b):\n",
    "    return b, a\n",
    "a = 10\n",
    "b = 20\n",
    "\n",
    "a, b = swap(a, b)\n",
    "print(a, b)"
   ]
  },
