   "source": [
    "#Removing odd index chars from a string"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "d0aaf4d2-cc84-4a57-bf41-3e543d0b678e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "ace\n",
      "pto\n"
     ]
    }
   ],
   "source": [
    "def odd(n):\n",
    "    result = ''\n",
    "    for i in range(len(n)):\n",
    "        if i % 2 == 0:\n",
    "            result = result + n[i]\n",
    "    return result\n",
    "\n",
    "print(odd('abcdef'))\n",
    "print(odd('python'))"
   ]
  }
 ],
