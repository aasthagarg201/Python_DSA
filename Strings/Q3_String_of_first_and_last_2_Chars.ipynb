   "source": [
    "def string_both_ends(str):\n",
    "    if len(str) < 2:\n",
    "        return '*'\n",
    "    return str[0:2] + str[-2:]\n",
    "\n",
    "print(string_both_ends('google'))\n",
    "print(string_both_ends('xo'))\n",
    "print(string_both_ends('x'))"
   ]
  }
