   "source": [
    "#Finding lCM of two numbers"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "adb8c699-4420-4b8c-86b1-a499517112be",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "250\n"
     ]
    }
   ],
   "source": [
    "def lcm(a, b):\n",
    "    x = max(a, b)\n",
    "    y = min(a, b)\n",
    "    for i in range(x, a * b + 1, x):           #range(start, stop, step)\n",
    "        if i % y == 0:\n",
    "            return i\n",
    "        return a * b\n",
    "a=10\n",
    "b=25\n",
    "print(lcm(a, b))  "
   ]
  }
 ],
