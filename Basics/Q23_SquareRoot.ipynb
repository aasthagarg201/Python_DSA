   "source": [
    "Finding square root of an integer with floor square root"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "6a2e2582-04f2-420f-ba1a-507fe8a4f5f2",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "3\n"
     ]
    }
   ],
   "source": [
    "def floorsqrt(n):\n",
    "    x = 1\n",
    "    while x * x <= n:\n",
    "        x += 1\n",
    "    return x - 1\n",
    "\n",
    "n=11\n",
    "print(floorsqrt(n))"
   ]
  },
