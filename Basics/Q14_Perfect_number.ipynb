   "source": [
    "#Function to check if the number is perfect"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "92dfc717-3631-4b7c-85f8-0d82c278d3e2",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "True\n",
      "False\n"
     ]
    }
   ],
   "source": [
    "def isPerfect(n):\n",
    "    sum = 0\n",
    "    for i in range(1, n):\n",
    "        if n % i == 0:\n",
    "            sum += i\n",
    "    return sum == n\n",
    "    \n",
    "print(\"True\" if isPerfect(6) else \"False\")\n",
    "print(\"True\" if isPerfect(15) else \"False\")"
   ]
  }
 ],
