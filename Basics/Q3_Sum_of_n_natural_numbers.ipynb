      "120\n"
     ]
    }
   ],
   "source": [
    "def findsum(n):\n",
    "    sum = 0\n",
    "    i = 1\n",
    "    while i <= n:\n",
    "        sum = sum + i\n",
    "        i = i + 1\n",
    "    return sum\n",
    "n=15\n",
    "print(findsum(n))"
   ]
  }
 ],
