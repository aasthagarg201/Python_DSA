   "source": [
    "The digital root is obtained by repeatedly adding the digits of a number until only a single digit remains."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "a09a3aec-d264-4dd8-89de-5ad374e0d8d9",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "9\n"
     ]
    }
   ],
   "source": [
    "def digitalroot(n):\n",
    "    res = 0\n",
    "    while n > 0 or res > 9:\n",
    "        if n == 0:\n",
    "            n = res\n",
    "            res = 0\n",
    "\n",
    "        res += n % 10\n",
    "        n //= 10\n",
    "    return res\n",
    "n = 99999\n",
    "print(digitalroot(n))"
   ]
  }
 ],
