    "#Decimal to Binary conversion"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "7679cbc4-01c2-4836-9709-31903bfb82b6",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "1100\n"
     ]
    }
   ],
   "source": [
    "def decimal(n):\n",
    "    binary = []\n",
    "\n",
    "    while n > 0:\n",
    "        bit = n % 2\n",
    "        binary.append(str(bit))\n",
    "        n //= 2\n",
    "\n",
    "    binary.reverse()\n",
    "    return \"\".join(binary)\n",
    "\n",
    "n=12\n",
    "print(decimal(n))"
   ]
  }
 ],
