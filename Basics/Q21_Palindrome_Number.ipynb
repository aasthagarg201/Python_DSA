   ],
   "source": [
    "def palindrome(n):\n",
    "    reverse = 0\n",
    "    x = abs(n)\n",
    "    while x != 0:\n",
    "        reverse = (reverse*10) + (x % 10)\n",
    "        x = x // 10\n",
    "    return (reverse == abs(n))\n",
    "    \n",
    "n=12321\n",
    "if palindrome(n) == True:\n",
    "    print(\"True\")\n",
    "else:\n",
    "    print(\"False\")"
   ]
  }
 ],
