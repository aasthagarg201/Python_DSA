   "source": [
    "#Function to find the nth term in the series 1,3,6,10,15,21....."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "dc9410b4-f1f6-4ae4-bbe7-3ba11348e4ed",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "15\n"
     ]
    }
   ],
   "source": [
    "def series(n):\n",
    "    ans = 0 \n",
    "    for i in range(1,n+1):\n",
    "        ans = ans + i\n",
    "        \n",
    "    return ans\n",
    "n=5\n",
    "print(series(n))"
   ]
  }
 ],
