   ],
   "source": [
    "def factorial(n):\n",
    "    ans = 1\n",
    "    i = 2\n",
    "    while(i <= n):\n",
    "        ans *= i\n",
    "        i += 1\n",
    "    return ans\n",
    "n=6\n",
    "print(factorial(n))"
   ]
  }
