    "def evenodd(n):\n",
    "    if (n%2==0):\n",
    "        return \"EVEN\"\n",
    "    else:\n",
    "        return \"ODD\"\n",
    "print(evenodd(16))\n",
    "print(evenodd(15))"
   ]
